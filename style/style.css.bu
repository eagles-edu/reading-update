}

.boxlist10 {
  background-color: #FFFAF0;
  background-color: rgba(255, 187, 61, .08);
  border-left: solid 2px #002786 !important;
  border-right: solid 5px #002786 !important;
}

.boxlist11 {
  background-color: #FFFAFA;
  background-color: rgba(255, 148, 148, .06)
}

.boxlist12 {
  background-color: #E0E4EE;
  background-color: rgba(0, 39, 134, .09)
}

.boxlist13 {
  background-color: #E5F1EA;
  background-color: rgba(0, 134, 53, 0.09)
}

.boxlist14 {
  background-color: #F4F0EA;
  background-color: rgba(210, 180, 140, 0.15)
}

.boxlist15 {
  background-color: #F8E6E8;
  background-color: rgba(224, 22, 43, 0.09)
}

.rowflex {
  display: -webkit-box;
  display: -webkit-flex;
  display: -moz-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-flex-wrap: wrap;
  -ms-flex-wrap: wrap;
  flex-wrap: wrap;
  position: relative;
  top: 0;
}

.columnf50,
.columnf50foo {
  -ms-box-flex: 50%;
  -webkit-box-flex: .50;
  -webkit-flex: 50%;
  -moz-box-flex: .5;
  -ms-flex: 50%;
  flex: 50%;
  padding: 0;
}

@media screen and (max-width: 640px) {

  .columnf50,
  .columnf50foo {
    -ms-box-flex: 100%;
    -webkit-box-flex: 1;
    -webkit-flex: 100%;
    -moz-box-flex: 1;
    -ms-flex: 100%;
    flex: 100%;
    padding: 0 1em;
    z-index: 4;
  }
}

.nomarall {
  margin: 0;
}
