@charset "utf-8";

:root {
  --content-width: 80%;
  /* fallback for small screens  */
  --content-max: 1075px;
  /* hard cap for large screens */
}

/* Reset and Base Styles */
*,
*::after,
*::before {
  text-rendering: geometricPrecision;
}

abbr,
address,
applet,
article,
aside,
big,
blockquote,
body,
center,
cite,
code,
dd,
del,
details,
dfn,
div,
dl,
fieldset,
figcaption,
figure,
footer,
form,
header,
hgroup,
html,
i,
iframe,
img,
ins,
kbd,
legend,
li,
mark,
menu,
nav,
object,
opera,
output,
p,
pre,
progress,
q,
ruby,
section,
small,
span,
strike,
strong,
sub,
sup,
summary,
table,
tbody,
td,
tfoot,
th,
thead,
tr,
ul,
video {
  border: 0;
  font: inherit;
  margin: 0;
  padding: 0;
  vertical-align: baseline;
}

article,
aside,
figcaption,
figure,
footer,
header,
hgroup,
menu,
nav,
section {
  display: block;
}

body {
  background: url('../pics/backgroud.webp') repeat top left;
  background-size: auto;
  color: #000000;
  font-family: "Open Sans", Verdana, Tahoma, sans-serif !important;
  font-size: inherit;
  line-height: inherit;
  margin: 0 auto;
  padding-left: 5%;
  padding-right: 5%;
}

ol,
ul {
  list-style: none;
  margin: 0;
}

blockquote,
q {
  quotes: none;
}

blockquote::after,
blockquote::before,
q::after,
q::before {
  content: none;
}

pre,
code,
kbd,
samp {
  background-color: #efeff0;
  border: 1px solid #dededf;
  border-radius: 2px;
  font-family: "Consolas", monospace;
  font-weight: 100;
  padding: 0 4px;
}

pre {
  padding: 8px;
}

pre code,
pre kbd,
pre samp {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
}

table {
  border-collapse: collapse;
  border-spacing: 0;
  font-family: "Open Sans", Verdana, Tahoma, sans-serif;
  margin: 0 auto 1em auto;
}

caption,
figcaption {
  font-style: italic;
  text-align: center;
}

a {
  text-decoration: none;
}

a:active,
a:focus,
a:hover {
  color: blue;
  text-decoration: underline;
}

a:link {
  color: #ff0000;
}

a:visited {
  color: #002786;
}

a.index_visited:active {
  color: #009000;
}

a.index_visited:focus,
a.index_visited:hover {
  color: #1c56e7;
  text-decoration: underline;
}

a.index_visited:link,
a.index_visited:visited {
  color: #002786;
}

img {
  max-width: 100%;
}

blockquote,
hr,
pre {
  margin-bottom: 6px;
}

dd,
dl,
figcaption,
figure,
img,
ol,
p,
ul {
  padding-bottom: 6px;
}

@media screen and (min-width: 768px) {
  figure {
    padding-left: 21px;
    padding-right: 21px;
  }

  blockquote,
  hr,
  pre {
    margin-bottom: 11px;
  }

  /* html {
    font-size: 75%;
  }*/
  ol,
  ul {
    margin-left: 34px;
  }

  dd,
  dl,
  figcaption,
  figure,
  img,
  ol,
  p,
  ul {
    padding-bottom: inherit;
  }

  table th,
  table td {
    line-height: inherit;
    padding: inherit;
  }
}

.bm12, .bm75 {
  margin-bottom: 0.75em;
}

.bm1 {
  margin-bottom: 1em;
}

/* Typography */
h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: "Open Sans", Geneva, Verdana, Tahoma, sans-serif;
  letter-spacing: 1px;
  padding-bottom: 5px;
}

h1 {
  color: red;
  font-weight: 600;
  text-align: center;
}

h1:first-child,
h2:first-child,
h3:first-child,
h4:first-child,
h5:first-child,
h6:first-child {
  padding-top: 0;
}

h2 {
  font-size: 1.8em;
}

h3 {
  font-size: 1.2rem;
  padding: 12px 0;
}

h4 {
  font-size: 0.6rem;
  font-weight: bold;
  padding: 12px 0;
}

h5 {
  font-size: 0.5rem;
  font-weight: normal;
  padding: 12px 0;
}

h6 {
  font-size: 0.3rem;
  font-style: italic;
  padding: 12px 0;
}

/* Layout Utilities */
.column22 {
  float: left;
  line-height: 1.5em;
  margin-left: 0;
  margin-right: 0;
  padding: 0;
  width: 50%;
}

.row22::after {
  clear: both;
  content: "";
  display: table;
}

/* Responsive Tweaks */
@media screen and (max-width: 480px) {
  div .boxlist6 {
    font-weight: 400 !important;
  }

  p .boxhead4 {
    font-weight: 500 !important;
    text-shadow: 0 0 0;
  }

  /* 
  .boxlist5 {
    text-shadow: 0.1vw 0.1vw 1px #bbb;
    width: 75% !important;
  }
    */
  .column22 {
    line-height: 1.6em;
    width: 100% !important;
  }

  .column33,
  .column44 {
    width: 100% !important;
  }
}

.intrinsic-container {
  height: 0;
  overflow: hidden;
  position: relative;
}

.intrinsic-container-16x9 {
  padding-bottom: 56.25%;
}

.intrinsic-container-4x3 {
  padding-bottom: 75%;
}

.intrinsic-container iframe {
  height: 100%;
  left: 0;
  position: absolute;
  top: 0;
  width: 100%;
}

/* Lists */
ol.parents12,
ul.parents,
ul.parentssm,
ul.parentscheck,
ul.parentsx,
ul.childsarrow,
ul.childscheck,
ul.childsx {
  list-style: none;
  margin: 0;
  padding: 0 0 0 6vw;
}

li.childsarrow {
  line-height: calc(12px + 1vw);
  margin: 0 calc(12px + 1vw) calc(1px + 0.5vw) 1.4em;
}

li.childsarrow::before {
  color: inherit;
  content: "\279E";
  font-weight: 300;
  padding-right: 0.7vw;
}

li.childscheck {
  line-height: calc(12px + 1vw);
  margin: 0 calc(12px + 1vw) calc(6px + 0.4vw) 1.4em;
}

li.childscheck::before {
  color: inherit;
  content: "\2713";
  font-weight: 300;
  padding-right: 0.7vw;
}

li.childsx {
  line-height: calc(12px + 1vw);
  margin: 0 calc(12px + 1vw) calc(1px + 0.5vw) 1.4em;
}

li.childsx::before {
  color: inherit;
  content: "\2717";
  font-weight: 300;
  padding-right: 0.7vw;
}

li.parents {
  line-height: calc(12px + 1vw);
  margin-bottom: 0.25em;
}

li.parents::before {
  color: inherit;
  content: "\2605";
  font-weight: 400;
  padding-right: 0.7vw;
}

li.parents12 {
  line-height: calc(12px + 0.3vw);
  margin-bottom: calc(4px + 0.9vw);
}

li.parents12::before {
  color: inherit;
  font-weight: 500;
  padding-right: 0.7vw;
}

li.parentscheck {
  line-height: calc(12px + 1vw);
  margin-bottom: calc(1px + 0.5vw);
}

li.parentscheck::before {
  color: inherit;
  content: "\2714";
  font-weight: 400;
  padding-right: 0.7vw;
}

li.parentsx {
  line-height: calc(12px + 1vw);
  margin-bottom: calc(1px + 0.5vw);
}

li.parentsx::before {
  color: inherit;
  content: "\2718";
  font-weight: 600;
  padding-right: 0.7vw;
}

li.parentssm {
  font-size: 0.8em !important;
  line-height: calc(9px + 0.5vw);
  margin-bottom: calc(1px + 0.5vw);
}

li.parentssm::before {
  color: inherit;
  content: "\2606";
  font-weight: 100;
  padding-right: 0.7vw;
}

