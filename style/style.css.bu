/* for cloze */

/*   new clamp sys*/

/* Shared interpolation: (100vw - 300px) / 1300  ==>  0 at 300px viewport, 1 at 1600px viewport */

/* h1: 22px → 28px */
h1,
.ExerciseTitle {
  font-size: clamp(22px,
      calc(22px + (28 - 22) * ((100vw - 300px) / 1300)),
      28px);
  line-height: normal;
}

/* textres13: 22px → 28px */
.textres13 {
  font-size: clamp(22px,
      calc(22px + (28 - 22) * ((100vw - 300px) / 1300)),
      28px);
  line-height: normal;
}

/* textres20 & #MainDiv: 20px → 28px (was 20→26 then jump; now seamless) */
.textres20 {
  font-size: clamp(19px,
      calc(19px + (28 - 19) * ((100vw - 300px) / 1300)),
      25px);
  line-height: 1.75em;
}

/* textres12: 18px → 24px */
.textres12,
div.ClozeBody,
#MainDiv,
.QuestionText,
p {
  font-size: clamp(18px,
      calc(18px + (24 - 18) * ((100vw - 300px) / 1300)),
      24px);
  line-height: 2em;
}

/* textres11 + instructions + nav buttons: 17.7px → 25px (enforce floor 17.7) */
.textres11,
#Instructions,
.NavButton,
.NavButtonDown,
.NavButtonUp, 
.ExerciseSubtitle {
  font-size: clamp(17.7px,
      calc(17.7px + (25 - 17.7) * ((100vw - 300px) / 1300)),
      25px);
  line-height: normal;
}

/* Optional: if you want consistent button sizing even when user zooms further,
     you could add a max-width breakpoint tweak, but usually clamp alone suffices. */




.lnhght115 {
  line-height: 1.15em;
}

.lnhght125 {
  line-height: 1.25em;

}

.lnhght15 {
  line-height: 1.5em;
}

.lnhght175 {
  line-height: 1.75em;
}

.lnhght20 {
  line-height: 2em;
}

.menuweight {
  font-size: inherit;
  font-weight: inherit;
}

.fw300 {
  font-weight: 300;
}

.fw500 {
  font-weight: 500;
}

.fw600 {
  font-weight: 600;
}

.fw700 {
  font-weight: 700;
}
.QuestionText {
  text-align: left;
  margin: 1em auto;
  font-size: 100%;
}

p {
  margin: 0px;
  text-align: left;
  text-indent: .35in;
}

p.rghtagln,
.rghtagln {
  text-align: right;
}

p.centagln,
.centalgn {
  text-align: center;
}

p.leftagln,
.leftalgn {
  text-align: left; }

.smb,
#ShowMethodButton {
  display: inline-block;
  margin-bottom: 1em;
  margin-top: 1em;
  text-align: right;
}

hr.new2{
  border: 0;
  box-sizing: border-box;   /* include the 1 px border in width */
  border-top: 1px solid slategray;
  margin: 10px auto;        /* auto left/right keeps it centred */
  max-width: var(--content-max);
  width: var(--content-width);
}