/* Utility */
/* Works perfectly on <p>, <div>, <span>, <td>, <th>, <li> */

.centxt {
  text-align: center;
}

.cenmar {
  text-align: center;
}

.cenmar a {
  display: inline-block;
}

.dblock {
  display: block;
}

.dinlineblk {
  display: inline-block;
}

.flextxtcen {
  display: flex;
  justify-content: center;
}

/* Media Controls 
audio,
.audiox {
  display: inline-block !important;
  margin: 0 auto .5em auto !important;
}

audio::-internal-media-controls-download-button {
  display: none;
}

audio::-webkit-media-controls-enclosure {
  overflow: hidden;
}

audio::-webkit-media-controls-panel {
  width: 100%;
  background-color: #87CEFA;
  background-color: rgba(135, 206, 250, .5);
}
*/
.nodisplay {
  display: none;
}

.w23 {
  width: 23px;
}

.w160 {
  width: 160px;
}

.cent {
  display: inline-block;
  text-align: center;
}

.top {
  vertical-align: top;
}

.middle {
  vertical-align: middle;
}

.bottom {
  vertical-align: bottom;
}

.GapBox {
  font-size: inherit;
}

.center-container {
  width: fit-content;
  margin: 0 auto;
}

.boxlist5,
.boxlist5t,
.boxlist6,
.boxlist7,
.boxlist8,
.boxlist9,
.boxlist10,
.boxlist11,
.boxlist12,
.boxlist13,
.boxlist14,
.boxlist15 {
  -webkit-border-radius: 3px;
  border-radius: 3px;
  box-shadow: 1px 1px 2px #b3b3b3;
  display: block;
  height: fit-content;
  margin: 1em auto;
  max-width: var(--content-max);
  padding: 1em;
  text-align: left;
  width: var(--content-width);
}

