{
  "files.exclude": {
    "**/.undo": true,
    "**/.undo/**": true,
    "**/.sto": true,
    "**/.sto/**": true
  },
  "search.exclude": {
    "**/.undo": true,
    "**/.undo/**": true
  },
  "files.watcherExclude": {
    "**/.undo/**": true,
    "**/.sto/**": true,
    "**/lib/python*/**": true
  },
  "markdownlint.config": {
    "MD034": false
},
  "[html]": {
    "editor.hover.enabled": "on"
  },
  "json.schemas": [
    {
      "fileMatch": [ ".vscode/launch.json" ],
      "url": "vscode://schemas/launch"
    }
  ],
  "js/ts.validate.enabled": false,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "json",
    "jsonc",
    "markdown",
    "css",
    "typescript",
    "typescriptreact"
  ],
  "editor.hover.delay": 200,
  "json.schemaDownload.enable": true,
  "json.enableSchemaStore": true,
  "html.validate.scripts": false,
  "html.validate.styles": false,
  "files.trimTrailingWhitespace": true,
  "python.analysis.extraPaths": [
    "/home/eagles/.local/lib/python3.10/site-packages"],
  "css.autoValidation": "Never",
  "css.styleSheets": [
    "style.css"
  ],
  "cSpell.words": [
    "backgroud",
    "boxhead",
    "centagln",
    "centalgn",
    "centinblk",
    "centxtinblk",
    "childsarrow",
    "childscheck",
    "childsx",
    "Chk",
    "colorblack",
    "dblock",
    "dinlineblk",
    "dlogindnt",
    "fieldlabel",
    "fieldlabelid",
    "fieldtype",
    "flextxtcen",
    "flextxtcent",
    "flextxtleft",
    "flextxtrght",
    "flextxtright",
    "Frm",
    "HOTPOTNET",
    "HPN",
    "hpnetresult",
    "inlineblk",
    "JCLOZE",
    "leftagln",
    "leftalgn",
    "lnhght",
    "lstnosty",
    "martop",
    "menuweight",
    "nomarall",
    "parentscheck",
    "parentssm",
    "parentsx",
    "rghtagln",
    "tbm",
    "textcenter",
    "vizoff",
    "vizon",
    "wrapfit",
    "wrapit"
  ],
  "taskManager.favorites": [
    "efast-copy/npm/format:check",
    "efast-copy/npm/html:check"
  ]
}
