{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "HTML CHECK FILE",
      "type": "shell",
      "command": "npm",
      "args": ["run", "html:check:file", "--", "${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "HTML FIX FILE",
      "type": "shell",
      "command": "npm",
      "args": ["run", "html:fix:apply", "--", "${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "HTML CHECK ROOT",
      "type": "shell",
      "command": "npm",
      "args": ["run", "html:check"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "HTML FIX ROOT",
      "type": "shell",
      "command": "npm",
      "args": ["run", "html:fix:apply"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
