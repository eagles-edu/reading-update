{
  "name": "efast-copy",
  "private": true,
  "version": "0.2.2.2",
  "description": "Static English reading site with deployment helpers and lint tooling.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eagles-edu/reading-update.git"
  },
  "bugs": {
    "url": "https://github.com/eagles-edu/reading-update/issues"
  },
  "homepage": "https://github.com/eagles-edu/reading-update#readme",
  "engines": {
    "node": "20.19.4"
  },
  "scripts": {
    "format": "prettier --write .htmlvalidate.json .prettierrc.json package.json && npm run html:fix:apply",
    "format:check": "prettier --check .htmlvalidate.json .prettierrc.json package.json && npm run html:fix",
    "html:check": "html-validate -c ./.htmlvalidate.json --ext html,htm .",
    "html:check:file": "html-validate -c ./.htmlvalidate.json --ext html,htm",
    "html:fix": "node ./scripts/html-repo-sweep.cjs",
    "html:fix:apply": "node ./scripts/html-repo-sweep.cjs --apply",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "modernize:cloze:dry": "node ./scripts/modernize-cloze-pages.cjs --dry-run",
    "modernize:cloze:apply": "node ./scripts/modernize-cloze-pages.cjs --apply",
    "modernize:cloze:prompt": "node ./scripts/modernize-cloze-pages.cjs --prompt",
    "clean:html-selfclose": "node ./scripts/clean-html-selfclosing.cjs",
    "clean:html-selfclose:apply": "node ./scripts/clean-html-selfclosing.cjs --apply",
    "sync:live": "bash ./scripts/sync-dev-to-live.sh",
    "sync:live:apply": "bash ./scripts/sync-dev-to-live.sh --apply",
    "efast:manifest": "bash ./scripts/efast-rsync-manifest.sh",
    "efast:manifest:apply": "bash ./scripts/efast-rsync-manifest.sh --apply"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^0.13.2",
    "@eslint/markdown": "^7.5.1",
    "archiver": "^7.0.1",
    "axe-core": "^4.11.4",
    "cheerio": "^1.2.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.39.4",
    "glob": "^7.2.3",
    "globals": "^16.5.0",
    "html-validate": "^10.17.0",
    "parse5": "^7.3.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3"
  }
}
