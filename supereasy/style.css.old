@charset "utf-8";
/* CSS Document */
/* http://meyerweb.com/eric/tools/css/reset/ 
   v2.0 | 20110126
   License: none (public domain)
*/
@import url('https://fonts.googleapis.com/css?family=Open+Sans:100,300,400,600,700,800|Roboto+Condensed:100,300,400,700|Roboto:100,300,400,500,700,900&display=swap&subset=vietnamese');
/* http://meyerweb.com/eric/tools/css/reset/ 
   v2.0 | 20110126
   License: none (public domain)
*/
.wrapper1 {
  font-family: 'Open Sans', sans-serif;
  font-size: calc(12px + 0.35vw); /* Responsive base font size */
  line-height: calc(12px + 1.05vw); /* Responsive Vertical Rhythm */
}

.main1 {
	width: 100%; /* For small screens */
	max-width: 1280px; /* For large screens */
	margin: auto; /* Center the container in the viewport */
	font-family: 'Open Sans', sans-serif;
}



hr.new2 {
  border-top: 1px solid slategray;
  margin:  35px auto 35px auto;
	width: 80%;
}

.boxlist5{
	color: #615550;
	vertical-align: top;
	text-align: left;
	font-weight: 400!important;
	text-shadow: 1px 1px 3px #bbb;
	border-radius: 7px;
	background: #F0EDE5;
	padding: 1.3em;
	width: 80%!important;
	max-width: 1280px;
	height: auto;
	box-shadow: 1px 2px 3px 1px #666;
	border-left: solid 15px #E0162B;
	border-right: solid 5px #E0162B;
	margin-top: 0px;
	margin-right: auto;
	margin-bottom: calc(12px + 1.2vw);
	margin-left: auto;
	font-size: calc(12px + .7vw); /* Responsive base font size */
}

/* Create two equal columns that float next to each other */



.column22 {
	float: left;
	width: 50%;
    padding: 0px 0px 0px 0px;
	margin-left: 0px;
	margin-right: 0px;
	line-height: 1.5em;
	font-family: 'Roboto Condensed',serif;
}

/* Clear floats after the columns */
.row22:after {
  content: "";
  display: table;
  clear: both;
}

													/* Responsive layout - makes the three columns stack on top of each other instead of next to each other */
@media screen and (max-width : 480px ){
	p.boxhead4  {
   text-shadow: 0px 0px 0px;
	font-weight: 500!important;
  }
	div.boxlist5  {
	text-shadow: .1vw .1vw 1px #bbb;
		
		width: 75%!important;
  }	
	div.boxlist6  {
	font-weight: 400!important;
  }	
	.column22 {
	width: 100%!important;
		line-height: 1.6em;

	
  }
 	.column33 {
    width: 100%!important;
  }
	.column44 {
    width: 100%!important;
  }
}



ol.parents12{
	list-style-position: outside;
	margin: 0;
	padding: 0px 0px 0px 3vw;
} 


/* Remove default bullets */

li.parents12::before {
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 500;
	padding-right: 0.7vw;
}

li.parents12 {
	margin-bottom: calc(4px + .9vw);
	line-height: calc(12px + .3vw);
}

/* unordered list - star bullet inherit */	
ul.parents{
	list-style-type: none;
	list-style-position: outside;
	margin: 0;
	padding: 0px 0px 0px 3vw;
} /* Remove default bullets */


li.parents::before {
	content: "\2605"; /* Unicode star bullet symbol */
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 400;
	padding-right: 0.7vw;

}

li.parents {
	margin-bottom: 0.25em;
	line-height: calc(12px + 1vw);
}

/* unordered list - star bullet inherit */	
ul.parentssm {
		list-style-type: none;
        list-style-position:outside;
        margin:0;
      padding: 0px 0px 0px 3vw;
} /* Remove default bullets */


li.parentssm::before {
	content: "\2606"; /* Unicode star bullet symbol */
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 100;
	padding-right: 0.7vw;
}

li.parentssm {
	margin-bottom: calc(1px + .5vw);
	line-height: calc(9px + .5vw);
	font-size: .8em!important;
}

/* unordered list - check inherit */	
ul.parentscheck{
		list-style-type: none;
        list-style-position:outside;
        margin:0;
       padding: 0px 0px 0px 3vw;
} /* Remove default bullets */


li.parentscheck::before {
	content: "\2714"; /* Unicode bullet symbol */
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 400;
	padding-right: 0.7vw;
}

li.parentscheck {
	margin-bottom: calc(1px + .5vw);
	line-height: calc(12px + 1vw);
}

/* unordered list - star bullet inherit */	
ul.parentsx {
		list-style-type: none;
        list-style-position:outside;
        margin:0;
        padding: 0px 0px 0px 3vw;
} /* Remove default bullets */


li.parentsx::before {
	content: "\2718"; /* Unicode bullet symbol */
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 600;
	padding: 0px 0px 0px 3vw;
}

li.parentsx {
	margin-bottom: calc(1px + .5vw);
	line-height: calc(12px + 1vw);
}

/* Child unordered list - Heavy Triangle-Headed Right Arrow bullet inherit */	
ul.childsarrow { 
		list-style-type: none;
        list-style-position:outside;
        margin:0;
        padding: 0px 0px 0px 3vw;

} /* Remove default bullets */

li.childsarrow::before {
	content: "\279E"; /* Unicode bullet symbol */
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 300;
	padding-right:0.7vw;
}

li.childsarrow {
	margin: 0px calc(12px + 1vw) calc(1px + .5vw) 1.4em;
	line-height: calc(12px + 1vw);
	
}										

/* Child unordered list - check Mark bullet inherit */	
ul.childscheck {
	list-style-type: none;
	list-style-position: outside;
	margin: 0;
	padding: 0px 0px 0px;

} /* Remove default bullets */

li.childscheck::before {
	content: "\2713"; /* Unicode bullet symbol */
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 300;
	padding-right:0.7vw;

}

li.childscheck {
	margin: 0px calc(12px + 1vw) calc(6px + .4vw) 1.4em;
	line-height: calc(12px + 1vw);
}										

/* Child unordered list - Ballot X bullet inherit */	
ul.childsx { 
		list-style-type: none;
        list-style-position:outside;
        margin:0;
        padding: 0px 0px 0px 3vw;

} /* Remove default bullets */

li.childsx::before {
	content: "\2717"; /* Unicode bullet symbol */
	color: inherit;  /* Bullet color */
	/* Optional tweaks */
	font-weight: 300;
	padding-right:0.7vw;
}

li.childsx {
	margin: 0px calc(12px + 1vw) calc(1px + .5vw) 1.4em;
	line-height: calc(12px + 1vw);
	
}




html, body, div, span, applet, object, iframe, h1, h2, h3, h4, h5, h6, p, blockquote, pre, a, abbr, acronym, address, big, cite, code, del, dfn, em, img, ins, kbd, q, s, samp, small, strike, strong, sub, sup, tt, var, b, u, i, center, dl, dt, dd, ol, ul, li, fieldset, form, label, legend, table, caption, tbody, tfoot, thead, tr, th, td, article, aside, canvas, details, embed, figure, figcaption, footer, header, hgroup, menu, nav, output, ruby, section, summary, time, mark, audio, video {
  margin: 0;
  padding: 0;
  border: 0;
  font-size: 100%;
  font: inherit;
  vertical-align: baseline; }
  
.intrinsic-container {
  position: relative;
  height: 0;
  overflow: hidden;
}
 
/* 16x9 Aspect Ratio */
.intrinsic-container-16x9 {
  padding-bottom: 56.25%;
}
 
/* 4x3 Aspect Ratio */
.intrinsic-container-4x3 {
  padding-bottom: 75%;
}
 
.intrinsic-container iframe {
  position: absolute;
  top:0;
  left: 0;
  width: 100%;
  height: 100%;
} 

