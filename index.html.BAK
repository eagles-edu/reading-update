                      />
                    </path>
                    <path
                      d="M9.95 8L10.62 10.02L12.75 10.02L11.03 11.27L11.69 13.28L9.95 12.02L8.22 13.28L8.88 11.27L7.15 10.02L9.28 10.02L9.95 8Z"
                      opacity="0.78"
                    >
                      <animate
                        attributeName="opacity"
                        begin="0.35s"
                        dur="2.2s"
                        repeatCount="indefinite"
                        values="0.24;0.82;0.24"
                      />
                    </path>
                  </g>
                </svg>
                <svg
                  class="theme-toggle__icon-sun"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <g
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-width="1.8"
                  >
                    <g opacity="0.92">
                      <animateTransform
                        attributeName="transform"
                        dur="14s"
                        repeatCount="indefinite"
                        type="rotate"
                        values="0 12 12;360 12 12"
                      />
                      <path d="M12 1.75V4.25" />
                      <path d="M12 19.75V22.25" />
                      <path d="M1.75 12H4.25" />
                      <path d="M19.75 12H22.25" />
                      <path d="M4.75 4.75L6.52 6.52" />
                      <path d="M17.48 17.48L19.25 19.25" />
                      <path d="M17.48 6.52L19.25 4.75" />
                      <path d="M4.75 19.25L6.52 17.48" />
                    </g>
                    <circle cx="12" cy="12" fill="currentColor" r="4.6">
                      <animate
                        attributeName="r"
                        dur="2.8s"
                        repeatCount="indefinite"
                        values="4.15;4.8;4.15"
                      />
                    </circle>
                    <circle cx="12" cy="12" opacity="0.24" r="7.1">
                      <animate
                        attributeName="r"
                        dur="2.8s"
                        repeatCount="indefinite"
                        values="6.1;7.9;6.1"
                      />
                      <animate
                        attributeName="opacity"
                        dur="2.8s"
                        repeatCount="indefinite"
                        values="0.24;0.08;0.24"
                      />
                    </circle>
                  </g>
                </svg>
              </span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container shell section-shell">
          <div class="hero-grid">
            <div>
              <span class="eyebrow">
                📚 Reading practice for Pre-A1–B2 learners
              </span>
              <h1>Build English reading fluency</h1>
              <h2>...one story at a time</h2>
              <p class="hero-copy">
                The Eagles American English Club, Ltd. gives students short
                leveled texts, useful vocabulary, audio support, comprehension
                checks, and teacher-friendly activities for class or self-study.
              </p>
              <div class="hero-actions" aria-hidden="true"></div>
            </div>
          </div>
          <!-- CHANGE: Levels are directly below the hero buttons area, but outside the hero two-column grid. -->
          <div class="hero-levels">
            <section id="levels" aria-labelledby="levels-title">
              <div class="section-heading">
                <h2 id="levels-title">CEFR<sup>&copy;</sup> Reading levels</h2>
                <p>
                  Students can move step by step from simple daily texts to
                  longer academic-style reading.
                </p>
              </div>

              <div class="levels">
                <a class="level-card pre-a1" href="#">
                  <span class="level-icon level-icon--split pre-a1"
                    ><span>Pre</span><span>A1</span></span
                  >
                  <h3>Starter Readers</h3>
                  <p>
                    Letters, sounds, simple words, pictures, and very short phrases.
                  </p>
                </a>
                <a class="level-card a1" href="#">
                  <span class="level-icon a1">A1</span>
                  <h3>First Readers</h3>
                  <p>
                    Short texts, familiar words, pictures, and simple present tense.
                  </p>
                </a>
                <a class="level-card a2" href="#">
                  <span class="level-icon a2">A2</span>
                  <h3>Everyday English</h3>
                  <p>
                    Stories, messages, notices, routines, hobbies, and school topics.
                  </p>
                </a>
                <a class="level-card b1" href="#">
                  <span class="level-icon b1">B1</span>
                  <h3>Confident Readers</h3>
                  <p>
                    Longer articles with opinions, reasons, examples, and
                    paragraph structure.
                  </p>
                </a>
                <a class="level-card b2" href="#">
                  <span class="level-icon b2">B2</span>
                  <h3>
                    Exam<br>
                    Ready
                  </h3>
                  <p>
                    Academic vocabulary, inference questions, summaries, and discussion tasks.
                  </p>
                </a>
              </div>

            </section>
          </div>
        </div>
      </section>

      <section id="sample-reading" class="section" aria-labelledby="sample-reading-title">
