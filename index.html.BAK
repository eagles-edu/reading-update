<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta
      name="description"
      content="A clean English reading homepage for learners with leveled texts, vocabulary support, quizzes, and teacher-friendly reading practice.">
    <script>
      (() => {
        const storageKey = "theme";
        const root = document.documentElement;

        try {
          const savedTheme = localStorage.getItem(storageKey);
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const theme =
            savedTheme === "light" || savedTheme === "dark"
              ? savedTheme
              : prefersDark
                ? "dark"
                : "light";

          root.dataset.theme = theme;
          root.style.colorScheme = theme;
        } catch {
          root.dataset.theme = "light";
          root.style.colorScheme = "light";
        }
      })();
    </script>
    <link
      href="favicon.ico"
      rel="shortcut icon"
      type="image/vnd.microsoft.icon"
    >
    <title>The Eagles Club | Reading Practice for English Learners</title>

    <style>
      :root {
        color-scheme: light;
        --accent: #b50010;
        --accent-contrast: #ffffff;
        --accent-strong: #86000c;
        --bg-accent: rgba(181, 0, 16, 0.08);
        --bg-accent-2: rgba(0, 39, 134, 0.08);
        --badge-accent: rgba(181, 0, 16, 0.1);
        --badge-accent-2: rgba(0, 39, 134, 0.12);
        --border-pre-a1: #9aa0a6;
        --border-a1: #7ca8ff;
        --border-a2: #93d66b;
        --border-b1: #f3b55b;
        --border-b2: #f07c7c;
        --cta-bg-end: #002786;
        --cta-bg-start: #b50010;
        --border: #8d929e;
        --focus-ring: rgba(0, 39, 134, 0.32);
        --max-width: 1180px;
        --muted: #5f6b82;
        --page-bg: #d3d9e5;
        --primary-color: #b50010;
        --primary-dark: #86000c;
        --primary: var(--primary-color);
        --space-1: clamp(8px, 0.75vw, 10px);
        --space-2: clamp(12px, 1.1vw, 14px);
        --space-3: clamp(16px, 1.8vw, 20px);
        --space-4: clamp(22px, 2.2vw, 28px);
        --space-5: clamp(30px, 3vw, 40px);
        --theme-toggle-icon-bg: rgba(255, 255, 255, 0.78);
        --theme-toggle-icon-bg-dark: rgba(255, 255, 255, 0.12);
        --theme-toggle-ink: #172033;
        --theme-toggle-ink-dark: #ffd76a;
        --radius-base: 3.667px;
        --radius-pill: 999px;
        --radius-1: var(--radius-base);
        --radius-2: calc(var(--radius-base) * 2);
        --radius-3: calc(var(--radius-base) * 3);
        --secondary-color: #e4e9f2;
        --shadow: 0 18px 45px rgba(0, 39, 134, 0.12);
        --feature-bg-end: #b50010;
        --feature-bg-start: #002786;
        --on-accent: #ffffff;
        --on-accent-muted: rgba(255, 255, 255, 0.78);
        --on-accent-soft: rgba(255, 255, 255, 0.82);
        --shell-bg: rgba(255, 255, 255, 0.92);
        --shell-shadow: 0 14px 34px rgba(0, 39, 134, 0.09);
        --surface: #ffffff;
        --surface-soft: #f3f5ff;
        --surface-strong: #ffffff;
        --tertiary-color: #002786;
        --text: #212121;
      }

      html[data-theme="dark"] {
        color-scheme: dark;
        --accent: #bfbfbf;
        --accent-contrast: #101010;
        --accent-strong: #e8e8e8;
        --bg-accent: rgba(255, 255, 255, 0.03);
        --bg-accent-2: rgba(255, 255, 255, 0.015);
        --badge-accent: rgba(255, 255, 255, 0.08);
        --badge-accent-2: rgba(255, 255, 255, 0.14);
        --border: #555555;
        --focus-ring: rgba(235, 235, 235, 0.34);
        --muted: #c2c2c2;
        --page-bg: #050505;
        --primary-color: #d9d9d9;
        --primary-dark: #f0f0f0;
        --secondary-color: #111111;
        --shadow: 0 18px 42px rgba(0, 0, 0, 0.5);
        --feature-bg-end: #323232;
        --feature-bg-start: #161616;
        --on-accent: #f4f4f4;
        --on-accent-muted: rgba(244, 244, 244, 0.76);
        --on-accent-soft: rgba(244, 244, 244, 0.84);
        --shell-bg: rgba(22, 22, 22, 0.94);
        --shell-shadow: 0 16px 34px rgba(0, 0, 0, 0.48);
        --surface: #262626;
        --surface-soft: #333333;
        --surface-strong: #141414;
        --tertiary-color: #efefef;
        --text: #f0f0f0;
        --cta-bg-end: #3e3e3e;
        --cta-bg-start: #1f1f1f;
      }

      html[data-theme="dark"] .theme-toggle {
        background: transparent;
        border-color: transparent;
        color: var(--theme-toggle-ink-dark);
      }

      html[data-theme="dark"] .theme-toggle:hover {
        border-color: rgba(255, 215, 106, 0.42);
      }

    html[data-theme="dark"] .theme-toggle__icon {
      background: var(--theme-toggle-icon-bg-dark);
      color: var(--theme-toggle-ink-dark);
    }

    html[data-theme="dark"] .brand {
      text-shadow: 0 1px 0 rgba(0, 0, 0, 0.28);
    }

      * {
        box-sizing: border-box;
      }

      html {
        color-scheme: light;
      }

      html[data-theme="dark"] {
        color-scheme: dark;
      }

      body {
        color: var(--text);
        line-height: 1.6;
        margin: 0;
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        background:
          radial-gradient(
            circle at top left,
            var(--bg-accent),
            transparent 32rem
          ),
          radial-gradient(
            circle at top right,
            var(--bg-accent-2),
            transparent 34rem
          ),
          var(--page-bg);
      }

      :focus-visible {
        outline: 3px solid var(--focus-ring);
        outline-offset: 3px;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .container {
        margin-inline: auto;
        width: min(100% - 32px, var(--max-width));
      }

      .shell {
        background: var(--shell-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-3);
        box-shadow: var(--shell-shadow);
        overflow: hidden;
      }

      .section-shell {
        display: grid;
        gap: var(--space-3);
        padding: var(--space-2) var(--space-4);
      }

      .site-header {
        background: transparent;
        padding: 12px 0 0;
        position: static;
      }

      .hub-banner {
        align-items: center;
        background: var(--primary-color);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: var(--radius-2);
        color: var(--secondary-color);
        display: flex;
        font-size: 0.85rem;
        font-weight: 700;
        justify-content: space-between;
        letter-spacing: 0.08em;
        line-height: 1;
        min-block-size: 18px;
        margin-top: var(--space-2);
        padding-block: 6px;
        padding-inline: calc(var(--space-2) * 1.9);
        width: 100%;
      }

      .hub-banner a {
        color: inherit;
        font-size: inherit;
        font-weight: inherit;
        text-decoration: none;
        transition: color 120ms ease, text-decoration-color 120ms ease;
      }

      .hub-banner a:hover,
      .hub-banner a:focus-visible {
        color: var(--accent-contrast);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .nav {
        align-items: center;
        display: flex;
        flex-direction: row;
        gap: var(--space-3);
        justify-content: flex-start;
        min-height: 56px;
        padding: 10px 0;
      }

      .brand {
        align-items: center;
        color: var(--tertiary-color);
        display: inline-flex;
        font-size: 1.14rem;
        font-weight: 950;
        gap: 10px;
        letter-spacing: 0.02em;
        text-shadow: 0 1px 0 rgba(255, 255, 255, 0.55);
      }

      .brand-title {
        color: var(--tertiary-color);
        display: inline-block;
        font-size: 1.08rem;
        font-variant-numeric: tabular-nums;
        font-weight: 950;
        letter-spacing: 0.01em;
        line-height: 1;
        text-shadow: 0 1px 0 rgba(255, 255, 255, 0.58);
        white-space: nowrap;
      }

      /* CHANGE: Header mark now uses the supplied logo as inline SVG, removing the external logo image dependency. */
      .brand-mark {
        background: linear-gradient(
          180deg,
          var(--surface-strong) 0%,
          var(--surface-soft) 100%
        );
        border-radius: var(--radius-1);
        box-shadow: var(--shadow);
        display: grid;
        height: 44px;
        overflow: hidden;
        place-items: center;
        width: 44px;
      }

      .brand-mark svg {
        display: block;
        height: 36px;
        width: 36px;
      }

      .nav-links {
        display: none;
      }

      .nav-actions {
        display: none;
      }

      .btn {
        align-items: center;
        border: 1px solid transparent;
        border-radius: var(--radius-2);
        cursor: pointer;
        display: inline-flex;
        font-weight: 800;
        justify-content: center;
        min-height: 44px;
        padding: 0 18px;
        transition:
          transform 160ms ease,
          box-shadow 160ms ease,
          background 160ms ease,
          border-color 160ms ease;
      }

      .btn:hover {
        transform: translateY(-1px);
      }

      .btn-primary {
        background: var(--primary);
        box-shadow: var(--shadow);
        color: var(--accent-contrast);
      }

      .btn-primary:hover {
        background: var(--primary-dark);
      }

      .btn-ghost {
        background: var(--surface);
        border-color: var(--border);
        color: var(--tertiary-color);
      }

      .btn-ghost:hover {
        border-color: var(--accent);
      }

      .header-link {
        align-items: center;
        color: var(--tertiary-color);
        display: inline-flex;
        font-size: 0.95rem;
        font-weight: 800;
        justify-content: center;
        text-decoration: none;
        white-space: nowrap;
      }

      .header-link:hover,
      .header-link:focus-visible {
        color: var(--primary);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .theme-toggle {
        align-items: center;
        appearance: none;
        background: transparent;
        border: 1px solid transparent;
        border-radius: var(--radius-pill);
        color: var(--theme-toggle-ink);
        cursor: pointer;
        display: inline-flex;
        justify-content: center;
        justify-self: end;
        min-height: 44px;
        padding: 8px;
        position: relative;
        transition:
          background-color 180ms ease,
          border-color 180ms ease,
          color 180ms ease,
          transform 180ms ease;
      }

      .theme-toggle:hover {
        border-color: rgba(15, 22, 41, 1);
        transform: translateY(-1px);
      }

      .theme-toggle__icon {
        align-items: center;
        background: var(--theme-toggle-icon-bg);
        border-radius: var(--radius-pill);
        color: var(--theme-toggle-ink);
        display: inline-flex;
        flex: 0 0 auto;
        height: 38px;
        justify-content: center;
        width: 38px;
      }

      .theme-toggle__icon svg {
        color: inherit;
        display: none;
        height: 100%;
        width: 100%;
      }

      .theme-toggle__icon[data-theme-icon="moon"] .theme-toggle__icon-moon,
      .theme-toggle__icon[data-theme-icon="sun"] .theme-toggle__icon-sun {
        display: block;
      }

      .theme-toggle:focus-visible {
        box-shadow: 0 0 0 3px rgba(47, 91, 227, 0.2);
        outline: none;
      }

      .hero {
        padding: var(--space-4) 0 var(--space-3);
      }

      /* CHANGE: Keep hero content in one column; no desktop two-column split. */
      .hero-grid {
        align-items: center;
        display: grid;
        gap: var(--space-5);
        grid-template-columns: 1fr;
      }

      .eyebrow {
        align-items: center;
        background: var(--secondary-color);
        border: 1px solid var(--tertiary-color);
        border-radius: var(--radius-2);
        color: var(--primary);
        display: inline-flex;
        font-size: 0.9rem;
        font-weight: 900;
        gap: var(--space-1);
        margin-bottom: var(--space-2);
        padding: 7px 12px;
      }

      h1,
      h2,
      h3 {
        color: var(--tertiary-color);
        line-height: 1.12;
        margin: 0;
      }

      h1 {
        color: var(--tertiary-color);
        letter-spacing: -0.04em;
        max-width: none;
        font-size: clamp(1.35rem, 3.55vw, 2.9rem);
        margin-top: 0.35rem;
        /* CHANGE: Let the intro heading use the full page width instead of a narrow column. */
        /* CHANGE: Reduced intro heading size by ~35%. */
      }

      .hero-copy {
        color: var(--muted);
        font-size: 1.15rem;
        margin: var(--space-3) 0 var(--space-4);
        max-width: 920px;
        /* CHANGE: Intro copy can spread wider so the hero area feels less crowded. */
      }

      .hero-actions {
        min-height: 0;
        /* CHANGE: Buttons removed, but the original vertical space is preserved. */
      }

      .hero-card {
        border: 1px solid var(--border);
        border-radius: var(--radius-3);
        box-shadow: var(--shadow);
        overflow: hidden;
        padding: var(--space-4);
        position: relative;
        background:
          radial-gradient(
            circle at top left,
            var(--bg-accent),
            transparent 34%
          ),
          radial-gradient(
            circle at bottom right,
            var(--bg-accent-2),
            transparent 36%
          ),
          var(--surface);
      }

      /* CHANGE: Mascot now sits inline to the left of the sample reading title. */
      .sample-title-row {
        align-items: center;
        display: flex;
        gap: var(--space-3);
        margin-bottom: var(--space-2);
      }

      .mascot-wrap {
        display: flex;
        flex: 0 0 auto;
      }

      .mascot-card {
        background: linear-gradient(
          180deg,
          var(--surface) 0%,
          var(--surface-soft) 100%
        );
        border-radius: var(--radius-1);
        box-shadow: var(--shadow);
        display: grid;
        height: 52px;
        place-items: center;
        width: 52px;
        /* CHANGE: Mascot now matches the header logo container size. */
      }

      .mascot-card img {
        height: 44px;
        object-fit: contain;
        width: 44px;
        /* CHANGE: Mascot image now matches the inline logo visual size. */
      }

    .reading-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-3);
      padding: var(--space-4);
    }

    .reading-panel header {
      display: flex;
      gap: var(--space-3);
      justify-content: space-between;
      margin-bottom: var(--space-3);
    }

    .sample-header {
      align-items: center;
      display: flex;
      gap: var(--space-3);
      justify-content: space-between;
      margin-bottom: var(--space-3);
    }

      .level-pill {
        background: var(--surface-soft);
        border-radius: var(--radius-pill);
        color: var(--tertiary-color);
        font-size: 0.82rem;
        font-weight: 900;
        padding: 6px 10px;
      }

      .sample-title {
        color: var(--tertiary-color);
        font-size: 1.45rem;
        margin-bottom: 0;
      }

      .sample-text {
        color: var(--muted);
      }

      .vocab-row {
        display: grid;
        gap: var(--space-2);
        grid-template-columns: 1fr;
        margin-top: var(--space-3);
      }

      .vocab-card {
        background: var(--surface-soft);
        border-left: 4px solid var(--primary);
        border-radius: var(--radius-2);
        font-size: 0.92rem;
        padding: 12px;
      }

      .vocab-card strong {
        color: var(--tertiary-color);
        display: block;
      }

      .stats {
        display: grid;
        gap: var(--space-3);
        grid-template-columns: 1fr;
        margin-top: var(--space-3);
      }

      .stat {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-3);
        padding: 16px;
      }

      .stat strong {
        color: var(--primary);
        display: block;
        font-size: 1.45rem;
        font-variant-numeric: tabular-nums;
        line-height: 1.1;
        min-width: 4ch;
      }

      .stat-counter strong {
        font-size: 1.45rem;
      }

      .stat-counter span {
        color: var(--muted);
        display: block;
        font-weight: 700;
        margin-top: 2px;
      }

      .section {
        padding: var(--space-3) 0;
      }

      .section-heading {
        align-items: end;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-3);
        justify-content: space-between;
        margin-bottom: var(--space-3);
      }

      .section-heading h2 {
        color: var(--tertiary-color);
        font-size: clamp(1.35rem, 2.7vw, 2.08rem);
        letter-spacing: -0.04em;
      }

      .section-heading p {
        color: var(--muted);
        margin: 0;
        max-width: 520px;
      }

      .card-grid {
        display: grid;
        gap: var(--space-4);
        grid-template-columns: 1fr;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-3);
        box-shadow: var(--shadow);
        padding: var(--space-4);
      }

      .icon {
        align-items: center;
        background:
          radial-gradient(
            circle at top left,
            color-mix(in srgb, var(--primary) 16%, transparent),
            transparent 60%
          ),
          var(--surface-soft);
        border: 1px solid color-mix(in srgb, var(--primary) 22%, var(--border));
        border-radius: var(--radius-2);
        box-shadow: 0 8px 18px rgba(0, 39, 134, 0.08);
        color: var(--primary);
        display: grid;
        height: 64px;
        margin-bottom: var(--space-4);
        place-items: center;
        width: 64px;
      }

      .icon svg {
        display: block;
        height: 30px;
        fill: currentColor;
        width: 30px;
      }

      html[data-theme="dark"] .icon {
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.42);
      }

      .card h3 {
        color: var(--tertiary-color);
        font-size: 1.25rem;
        margin-bottom: 8px;
      }

      .card p {
        color: var(--muted);
        margin: 0;
      }

      .levels {
        display: grid;
        gap: var(--space-4);
        grid-template-columns: 1fr;
        margin-bottom: var(--space-3);
        /* CHANGE: Keeps the level-card and sample-card spacing on the same rhythm as the rest of the page. */
      }

      .level-card {
        background:
          radial-gradient(
            circle at top left,
            var(--level-splash, rgba(0, 0, 0, 0.03)),
            transparent 34%
          ),
          radial-gradient(
            circle at bottom right,
            var(--level-splash-2, rgba(0, 0, 0, 0.015)),
            transparent 38%
          ),
          var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-3);
        border-top: 5px solid var(--level-accent, var(--primary));
        color: inherit;
        cursor: pointer;
        display: block;
        min-height: 12.5rem;
        padding: 10px;
        position: relative;
        overflow: hidden;
        text-decoration: none;
        transition:
          transform 240ms ease,
          box-shadow 240ms ease,
          border-color 240ms ease,
          border-top-color 240ms ease,
          background-color 240ms ease;
        will-change: transform;
      }

      .level-card::before {
        content: "";
        inset: -1px;
        position: absolute;
        z-index: 0;
        background: linear-gradient(
          125deg,
          transparent 24%,
          rgba(255, 255, 255, 0.22) 48%,
          transparent 72%
        );
        opacity: 0;
        pointer-events: none;
        transform: translateX(-46%) skewX(-14deg);
        transition:
          opacity 320ms ease,
          transform 520ms ease;
      }

      .level-card:hover,
      .level-card:focus-visible {
        border-color: color-mix(
          in srgb,
          var(--level-accent, var(--primary)) 70%,
          var(--border)
        );
        box-shadow:
          0 22px 42px rgba(15, 23, 42, 0.14),
          0 0 0 1px
            color-mix(
              in srgb,
              var(--level-accent, var(--primary)) 34%,
              transparent
            );
        transform: translateY(-7px);
      }

      .level-card:hover::before,
      .level-card:focus-visible::before {
        opacity: 1;
        transform: translateX(38%) skewX(-14deg);
      }

      .level-card:hover::after,
      .level-card:focus-visible::after {
        opacity: 0.62;
        transform: scale(1.08);
      }

      .level-card:focus-visible {
        outline: 3px solid
          color-mix(in srgb, var(--level-accent, var(--primary)) 72%, #ffffff);
        outline-offset: 4px;
      }

      .pre-a1 {
        border: 2px solid var(--border-pre-a1);
        border-top: 7px solid var(--border-pre-a1, var(--primary));
      }
      .a1 {
        border: 2px solid var(--border-a1);
        border-top: 7px solid var(--border-a1, var(--primary));
      }
      .a2 {
        border: 2px solid var(--border-a2);
        border-top: 7px solid var(--border-a2, var(--primary));
      }
      .b1 {
        border: 2px solid var(--border-b1);
        border-top: 7px solid var(--border-b1, var(--primary));
      }
      .b2 {
        border: 2px solid var(--border-b2);
        border-top: 7px solid var(--border-b2, var(--primary));
      }

      .level-card::after {
        content: "";
        inset: auto -22% -28% auto;
        position: absolute;
        z-index: 0;
        border-radius: var(--radius-pill);
        width: 10rem;
        height: 10rem;
        background: radial-gradient(
          circle,
          color-mix(
            in srgb,
            var(--level-accent, var(--primary-color)) 34%,
            transparent
          ),
          transparent 72%
        );
        opacity: 0.42;
        pointer-events: none;
      }

      html[data-theme="dark"] .level-card {
        border-color: rgba(255, 255, 255, 0.12);
        box-shadow: 0 18px 38px rgba(0, 0, 0, 0.42);
      }

      html[data-theme="dark"] .level-card:hover,
      html[data-theme="dark"] .level-card:focus-visible {
        border-color: color-mix(in srgb, var(--level-accent) 86%, #ffffff);
        box-shadow:
          0 24px 46px rgba(0, 0, 0, 0.55),
          0 0 0 1px color-mix(in srgb, var(--level-accent) 42%, transparent);
        transform: translateY(-8px);
      }

      html[data-theme="dark"] .level-card::after {
        background: radial-gradient(
          circle,
          color-mix(in srgb, var(--level-accent) 54%, transparent),
          transparent 72%
        );
        opacity: 0.7;
      }

      html[data-theme="dark"] .level-card::before {
        background: linear-gradient(
          125deg,
          transparent 22%,
          rgba(255, 255, 255, 0.14) 48%,
          transparent 72%
        );
      }

      .level-card > * {
        position: relative;
        z-index: 1;
      }

      .level-card:nth-child(1) {
        --level-accent: #9aa0a6;
        --level-splash: rgba(154, 160, 166, 0.18);
        --level-splash-2: rgba(154, 160, 166, 0.06);
      }

      .level-card:nth-child(2) {
        --level-accent: #7ca8ff;
        --level-splash: rgba(124, 168, 255, 0.2);
        --level-splash-2: rgba(124, 168, 255, 0.06);
      }

      .level-card:nth-child(3) {
        --level-accent: #93d66b;
        --level-splash: rgba(147, 214, 107, 0.2);
        --level-splash-2: rgba(147, 214, 107, 0.06);
      }

      .level-card:nth-child(4) {
        --level-accent: #f3b55b;
        --level-splash: rgba(243, 181, 91, 0.2);
        --level-splash-2: rgba(243, 181, 91, 0.06);
      }

      .level-card:nth-child(5) {
        --level-accent: #f07c7c;
        --level-splash: rgba(240, 124, 124, 0.2);
        --level-splash-2: rgba(240, 124, 124, 0.06);
      }

      .level-icon {
        border-radius: var(--radius-1);
        box-shadow: var(--shadow);
        color: var(--secondary-color);
        display: inline-grid;
        font-size: 2.15rem;
        font-weight: 900;
        height: 4rem;
        margin-bottom: 12px;
        place-items: center;
        line-height: 1;
        white-space: nowrap;
        width: 4rem;
        background:
          radial-gradient(
            circle at top left,
            rgba(255, 255, 255, 0.34),
            transparent 34%
          ),
          linear-gradient(
            135deg,
            var(--level-accent, var(--primary-color)),
            color-mix(
              in srgb,
              var(--level-accent, var(--primary-color)) 56%,
              #111111
            )
          );
        transition:
          transform 240ms ease,
          box-shadow 240ms ease,
          filter 240ms ease;
      }

      .level-icon--split {
        line-height: 0.55;
        white-space: normal;
      }

      .level-icon--split span {
        display: block;
        font-size: 1.76rem;
      }

      html[data-theme="dark"] .level-icon {
        border-color: rgba(255, 255, 255, 0.18);
        color: #f8fbff;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9);
        background:
          radial-gradient(
            circle at top left,
            rgba(255, 255, 255, 0.16),
            transparent 26%
          ),
          linear-gradient(
            135deg,
            color-mix(
              in srgb,
              var(--level-accent, var(--primary-color)) 88%,
              #000000
            ),
            color-mix(
              in srgb,
              var(--level-accent, var(--primary-color)) 62%,
              #000000
            )
          );
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.58);
      }

      .level-card:hover .level-icon,
      .level-card:focus-visible .level-icon {
        transform: translateY(-3px) scale(1.06) rotate(-2deg);
        filter: saturate(1.08) brightness(1.04);
      }

      .level-card h3 {
        color: var(--tertiary-color);
        font-size: 1.7rem;
        letter-spacing: -0.02em;
      }

      html[data-theme="dark"] .level-card h3 {
        font-size: 1.8rem;
      }

      .level-card p {
        font-size: 1.08rem;
        line-height: 1.7;
        max-width: 24ch;
      }

      html[data-theme="dark"] .level-card p {
        font-size: 1.1rem;
      }

      .feature-strip {
        align-items: center;
        background:
          linear-gradient(
            135deg,
            var(--feature-bg-start),
            var(--feature-bg-end)
          ),
          var(--surface);
        border-radius: var(--radius-3);
        color: var(--on-accent);
        display: grid;
        gap: var(--space-5);
        grid-template-columns: 1fr;
        padding: var(--space-5);
      }

      .feature-strip p {
        color: var(--on-accent-muted);
      }

      .check-list {
        display: grid;
        gap: var(--space-2);
        grid-template-columns: 1fr;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .check-list li {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: var(--radius-2);
        padding: 14px 16px;
      }

      .cta {
        background:
          linear-gradient(135deg, var(--cta-bg-start), var(--cta-bg-end)),
          var(--accent);
        border-radius: var(--radius-3);
        color: var(--on-accent);
        padding: var(--space-5);
        text-align: center;
      }

      .cta p {
        color: var(--on-accent-soft);
        margin: var(--space-2) auto var(--space-4);
        max-width: 660px;
      }

      .site-footer {
        color: var(--secondary-color);
        margin-top: var(--space-4);
        margin-bottom: var(--space-4);
      }

      .site-footer .shell {
        background: var(--tertiary-color);
        border-color: color-mix(in srgb, var(--secondary-color) 16%, var(--tertiary-color));
      }

      .site-footer .section-shell {
        padding: var(--space-3) var(--space-4);
      }

      .footer-row {
        display: flex;
        align-items: center;
        flex-direction: row;
        flex-wrap: wrap;
        gap: var(--space-2);
        justify-content: space-between;
        padding-top: 0;
      }

      @media (min-width: 681px) {
        .card-grid,
        .levels,
        .stats {
          grid-template-columns: repeat(2, 1fr);
        }

        .vocab-row {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .check-list {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 380px) {
        :root {
          --space-1: 8px;
          --space-2: 10px;
          --space-3: 14px;
          --space-4: 18px;
          --space-5: 24px;
        }

        .container {
          width: min(100% - 20px, var(--max-width));
        }

        .section-shell {
          gap: var(--space-3);
          padding: 10px 14px;
        }

        .nav {
          gap: 8px;
          min-height: 48px;
          padding: 8px 0;
        }

        .nav-actions {
          align-items: center;
          display: flex;
          flex: 0 0 auto;
          justify-content: flex-end;
          margin-left: auto;
        }

        .nav-links,
        .nav-actions .header-link {
          display: none;
        }

      .brand {
        font-size: 1rem;
        gap: 6px;
      }

      .brand-title {
        font-size: 0.98rem;
        letter-spacing: 0.01em;
      }

        .brand-mark {
          height: 40px;
          width: 40px;
        }

      .brand-mark svg {
        height: 32px;
        width: 32px;
      }

      .brand-title {
        font-size: 1.14rem;
      }

        .hero {
          padding: 24px 0;
        }

        .eyebrow {
          font-size: 0.8rem;
          margin-bottom: 14px;
          padding: 6px 10px;
        }

        h1 {
          font-size: clamp(1.25rem, 8vw, 1.75rem);
        }

        .hero-copy {
          font-size: 1rem;
          margin: var(--space-2) 0 var(--space-3);
        }

        .hero-card {
          padding: var(--space-3);
        }

        .reading-panel {
          padding: var(--space-3);
        }

        .sample-title {
          font-size: 1.2rem;
        }

      .sample-title-row {
        gap: var(--space-2);
      }

      .sample-header {
        gap: var(--space-2);
      }

        .feature-strip,
        .cta {
          padding: var(--space-3);
        }
      }

      @media (min-width: 901px) {
      .nav {
        justify-content: space-between;
        flex-direction: row;
        gap: var(--space-4);
        padding: 0;
      }

      .brand {
        font-size: 1.26rem;
        letter-spacing: 0.02em;
      }

        .nav-actions {
          align-items: center;
          display: flex;
          flex-direction: row;
          gap: var(--space-3);
          margin-left: auto;
          width: auto;
        }

        .theme-toggle,
        .nav-actions .header-link {
          width: auto;
        }

        .hero {
          padding: var(--space-4) 0 var(--space-3);
        }

        .feature-strip {
          grid-template-columns: 0.75fr 1.25fr;
        }

        .card-grid {
          grid-template-columns: repeat(3, 1fr);
        }

        .levels {
          grid-template-columns: repeat(5, 1fr);
        }

        .stats {
          grid-template-columns: repeat(4, 1fr);
        }

        .section-heading {
          align-items: end;
          flex-direction: row;
        }
      }

      @media (max-width: 520px) {
        .site-footer .section-shell {
          padding: var(--space-3) var(--space-3);
        }

        .footer-row {
          align-items: flex-start;
          flex-direction: column;
          gap: 6px;
        }
      }

      .txt-2ndy {
        color: var(--secondary-color);
      }

      html[data-theme="dark"] .txt-2ndy {
        color: var(--tertiary-color);
      }
    </style>
  </head>

