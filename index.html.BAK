              </div>
              <h2 id="sample-reading-title" class="sample-title">A Market Morning</h2>
            </div>
            <p class="sample-text">
              Linh goes to the market before school. She buys fresh fruit,
              asks the seller three questions, and learns a new word from an
              English sign near the shop.
            </p>
            <div class="vocab-row">
              <div class="vocab-card">
                <strong>fresh</strong>new or recently made
              </div>
              <div class="vocab-card">
                <strong>seller</strong>a person who sells things
              </div>
              <div class="vocab-card">
                <strong>near</strong>not far away
              </div>
            </div>

            <div class="stats">
              <div class="stat">
                <strong data-count-target="250" data-count-suffix="+">0</strong>
                texts
              </div>
              <div class="stat">
                <strong data-count-target="5">0</strong>
                levels
              </div>
              <div class="stat">
                <strong data-count-target="10" data-count-suffix=" min">0</strong>
                daily
              </div>
              <div class="stat stat-counter">
                <strong
                  data-visit-count
                  data-count-target="0"
                  aria-live="polite"
                >--</strong>
                <span>visits</span>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section id="library" class="section">
        <div class="container">
          <div class="feature-strip">
            <div>
              <h2 class="txt-2ndy">Explore the library</h2>
              <p>
                Browse by level, topic, skill focus, or lesson length. Perfect
                for homework, classroom warmups, and extra fluency practice.
              </p>
            </div>

            <ul class="check-list">
              <li>✅ Daily life stories</li>
              <li>✅ Science and technology</li>
              <li>✅ Culture and travel</li>
              <li>✅ Exam-style practice</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="features" class="section">
        <div class="container shell section-shell">
          <div class="section-heading">
            <h2>Designed for real reading growth.</h2>
            <p>
              Each lesson helps learners understand the text, notice useful
              language, and speak or write about what they read.
            </p>
          </div>

          <div class="card-grid">
            <article class="card">
              <div class="icon" aria-hidden="true">
                <svg viewBox="0 0 32 32">
                  <use href="images/icons/icomoon/symbol-defs.svg#icon-headphones"></use>
                </svg>
              </div>
              <h3>Read and listen</h3>
              <p>
                Students can read silently, listen for pronunciation, then read
                aloud for fluency.
              </p>
            </article>

            <article class="card">
              <div class="icon" aria-hidden="true">
                <svg viewBox="0 0 32 32">
                  <use href="images/icons/icomoon/symbol-defs.svg#icon-help"></use>
                </svg>
              </div>
              <h3>Check understanding</h3>
              <p>
                Quick comprehension questions help students prove they
                understood the main ideas.
              </p>
            </article>

            <article class="card">
              <div class="icon" aria-hidden="true">
                <svg viewBox="0 0 32 32">
                  <use href="images/icons/icomoon/symbol-defs.svg#icon-key"></use>
                </svg>
              </div>
              <h3>Use new words</h3>
              <p>
                Vocabulary boxes, example sentences, and review tasks turn
                reading into active learning.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="teachers" class="section">
        <div class="container">
          <div class="cta">
            <h2 class="txt-2ndy">Give every lesson a clear reading routine.</h2>
            <p>
              Use one text for preview vocabulary, silent reading, audio
              shadowing, comprehension questions, and a final speaking task.
            </p>
            <a class="btn btn-ghost" href="#">Create a Free Teacher Account</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container shell section-shell">
        <div class="footer-row">
          <span>© <span data-current-year></span> The Eagles Club</span>
          <span>Reading • Vocabulary • Fluency</span>
        </div>
      </div>
    </footer>

    <script>
      (() => {
        const storageKey = "theme";
        const visitStorageKey = "visit-count";
        const visitSessionKey = "visit-count-session";
        const root = document.documentElement;
        const toggle = document.querySelector("[data-theme-toggle]");
        const icon = toggle?.querySelector("[data-theme-toggle-icon]");
        const yearNode = document.querySelector("[data-current-year]");
        const visitCountNode = document.querySelector("[data-visit-count]");
        const metricNodes = Array.from(
          document.querySelectorAll("[data-count-target]"),
        );

        if (yearNode) {
          yearNode.textContent = String(new Date().getFullYear());
        }

        const getCookie = (name) => {
          const prefix = `${name}=`;
          return document.cookie
            .split("; ")
            .find((entry) => entry.startsWith(prefix))
            ?.slice(prefix.length) || "";
        };

        const setSessionCookie = (name) => {
          document.cookie = `${name}=1; path=/; Max-Age=3600; SameSite=Lax`;
        };

        const runSpinCounter = (
          node,
          target,
          { suffix = "", duration = 2200 } = {},
        ) => {
          const start = performance.now();
          const startValue = 0;
          const animateFrame = (now) => {
            const elapsed = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(2, -10 * elapsed);
            const value = Math.round(startValue + (target - startValue) * eased);
            node.textContent = `${value}${suffix}`;

            if (elapsed < 1) {
              requestAnimationFrame(animateFrame);
            } else {
              node.textContent = `${target}${suffix}`;
            }
          };
          requestAnimationFrame(animateFrame);
        };

        const getCounterTarget = async (node) => {
          if (node === visitCountNode) {
            try {
              const saved = Number(localStorage.getItem(visitStorageKey));
              const currentValue =
                Number.isFinite(saved) && saved >= 100 ? saved : 100;
              const sessionSeen = Boolean(getCookie(visitSessionKey));
              const nextValue = sessionSeen ? currentValue : currentValue + 1;

              localStorage.setItem(visitStorageKey, String(nextValue));
              if (!sessionSeen) {
                setSessionCookie(visitSessionKey);
              }

              return nextValue;
            } catch {
              return 100;
            }
          }

          const value = Number(node.dataset.countTarget);
          return Number.isFinite(value) ? value : null;
        };

        const animateMetrics = async () => {
          await new Promise((resolve) => window.setTimeout(resolve, 330));

          const jobs = metricNodes.map(async (node) => {
            const target = await getCounterTarget(node);
            if (target === null) {
              node.textContent = "—";
              return;
            }

            const suffix = node.dataset.countSuffix || "";
            node.textContent = "0";
            runSpinCounter(node, target, { suffix });
          });

          await Promise.all(jobs);
        };

        if (!toggle || !icon) {
          return;
        }

        const syncThemeToggle = (theme) => {
          const darkMode = theme === "dark";
          toggle.setAttribute("aria-pressed", String(darkMode));
          toggle.setAttribute(
            "aria-label",
            darkMode ? "Switch to light theme" : "Switch to dark theme",
          );
          icon.setAttribute("data-theme-icon", darkMode ? "sun" : "moon");
        };

        const applyTheme = (theme, persist = true) => {
          const nextTheme = theme === "dark" ? "dark" : "light";

          root.dataset.theme = nextTheme;
          root.style.colorScheme = nextTheme;
          syncThemeToggle(nextTheme);

          if (persist) {
            try {
              localStorage.setItem(storageKey, nextTheme);
            } catch {
              // Ignore storage failures and keep the visible theme in sync.
            }
          }
        };

        const statsRow = document.querySelector(".stats");
        let countersStarted = false;
        const startCountersOnce = () => {
          if (countersStarted) {
            return;
          }

          countersStarted = true;
          animateMetrics();
        };

        if (statsRow && "IntersectionObserver" in window) {
          const observer = new IntersectionObserver(
            (entries, io) => {
              if (entries.some((entry) => entry.isIntersecting)) {
                io.disconnect();
                startCountersOnce();
              }
            },
            { threshold: 0.35 },
          );

          observer.observe(statsRow);
        } else {
          startCountersOnce();
        }

        applyTheme(root.dataset.theme || "light", false);
        toggle.addEventListener("click", () => {
          applyTheme(root.dataset.theme === "dark" ? "light" : "dark");
        });
      })();
    </script>
  </body>
</html>
