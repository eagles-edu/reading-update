            <button
              class="theme-toggle"
              type="button"
              data-theme-toggle
              aria-pressed="false"
              aria-label="Switch to dark theme"
            >
              <span
                class="theme-toggle__icon"
                aria-hidden="true"
                data-theme-toggle-icon
                data-theme-icon="moon"
              >
                <svg
                  class="theme-toggle__icon-moon"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <defs>
                    <mask id="theme_moon_cutout">
                      <rect width="24" height="24" fill="#fff" />
                      <circle cx="12.95" cy="7.95" fill="#000" r="10.1" />
                    </mask>
                  </defs>
                  <g fill="currentColor">
                    <circle
                      cx="10.8"
                      cy="13.2"
                      r="10.3"
                      mask="url(#theme_moon_cutout)"
                    >
                      <animateTransform
                        attributeName="transform"
                        dur="4.8s"
                        repeatCount="indefinite"
                        type="rotate"
                        values="-2 12 12;2 12 12;-2 12 12"
                      />
                    </circle>
